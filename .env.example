# =============================================================================
# AI Personal Teacher System - Environment Variables
# Copy this file to .env and update values for your environment
# =============================================================================

# --------------- Application ---------------
APP_NAME=ai-personal-teacher
APP_ENV=development
APP_PORT=8000

# --------------- Frontend ---------------
VITE_API_URL=http://localhost:8000/api/v1

# --------------- Database (PostgreSQL) ---------------
POSTGRES_DB=leen_ai
POSTGRES_USER=leen
POSTGRES_PASSWORD=leen_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://leen:leen_dev_password@localhost:5432/leen_ai

# --------------- Redis ---------------
REDIS_HOST=localhost
REDIS_PORT=6379
